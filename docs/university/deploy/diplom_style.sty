    labelsep=custom
}
% Вставка картинки 1 - path, 2 - <label>, 3 - label_text, 4 - scale
\newcommand{\image}[4]{
    \begin{figure}[ht]
    \begin{center}
    \scalebox{#4}{
        % draft - пустая картинка. Ускоряет время компиляции
        % \includegraphics[draft]{#1}
        \includegraphics{#1}
    }

    \caption{
        \label{#2}#3}
    \end {center}
    \vspace{-1em}
    \end {figure}
}

% Листинги
\usepackage{minted}
% Нумерация в пределах раздела
\counterwithin{listing}{section}
% тема
\usemintedstyle{colorful} %{bw}
% \usemintedstyle{bw} %{bw}

% Название листинга
\renewcommand\listingscaption{Листинг}
% Вставка лиситнга 1 - файл, 2 - <label>, 3 - подпись, 4 - тип файла
\newcommand{\sourcecode}[4]{
    \begin{listing}[ht]
        \inputminted{#4}{#1}
        \vspace{-1em}
        \caption{#3}
        \label{#2}
    \end{listing}
}


