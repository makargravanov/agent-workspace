\usepackage{enumitem}
\newlength{\firstleveldashwidth}
\newlength{\firstleveldashlabelwidth}
\newlength{\firstleveldashspacewidth}
\settowidth{\firstleveldashlabelwidth}{\textendash}
\settowidth{\firstleveldashspacewidth}{\ }
\setlength{\firstleveldashwidth}{\dimexpr\firstleveldashlabelwidth+\firstleveldashspacewidth\relax}
\setlist[itemize,1]{label=\textendash, labelindent=\parindent, labelwidth=\firstleveldashlabelwidth, labelsep=\firstleveldashspacewidth, leftmargin=0pt, itemindent=\dimexpr\parindent+\firstleveldashwidth\relax, listparindent=0pt, itemsep=0pt, topsep=0pt, parsep=0pt, partopsep=0pt, align=left}
\setlist[itemize,2]{label=\textendash, labelindent=25mm, labelwidth=1.5em, leftmargin=!, labelsep=0.5em, itemindent=0pt, itemsep=0pt, topsep=0pt, parsep=0pt, partopsep=0pt, align=left}
\setlist[enumerate,1]{label=\arabic*), labelindent=25mm, labelwidth=1.5em, leftmargin=!, labelsep=0.5em, itemindent=0pt, itemsep=0pt, topsep=0pt, parsep=0pt, partopsep=0pt, align=left}
\setlist[enumerate,2]{label=\arabic*), labelindent=25mm, labelwidth=1.5em, leftmargin=!, labelsep=0.5em, itemindent=0pt, itemsep=0pt, topsep=0pt, parsep=0pt, partopsep=0pt, align=left}

